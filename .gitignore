# ===========================================
# .gitignore — Dashboard de Suporte Técnico
# ===========================================

# ---- Ambiente e Segredos ----
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
*.p12
*.pfx
secrets/
config/secrets.json

# ---- Node.js / NPM ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.pnp.*
package-lock.json

# ---- Build / Dist / Cache ----
dist/
build/
.cache/
.parcel-cache/
.vite/
out/

# ---- Logs ----
logs/
*.log
*.log.*

# ---- Editores e IDEs ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace
.editorconfig

# ---- Agentes e Ferramentas Internas ----
.agents/
.gemini/

# ---- Sistema Operacional ----
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---- Arquivos Temporários ----
*.tmp
*.temp
*.swp
*.bak
*.orig

# ---- Cobertura de Testes ----
coverage/
.nyc_output/

.vercel
